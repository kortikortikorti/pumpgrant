# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Platform wallet private key (base58 or JSON array format)
# If not set, will load from platform-wallet.json or generate a new one
PLATFORM_WALLET_PRIVATE_KEY=

# Encryption (for beneficiary wallet encryption)
ENCRYPTION_SECRET=change-this-to-another-random-secret-string

# Fee Monitor Bot
FEE_CHECK_INTERVAL_MS=30000

# Upstash Redis (Vercel KV)
KV_REST_API_URL=https://your-redis.upstash.io
KV_REST_API_TOKEN=your-upstash-token
